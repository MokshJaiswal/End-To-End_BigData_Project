# Databricks
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.XX.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Azure Service Principal (shared by ADF + Synapse connections)
AZURE_SP_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_SP_CLIENT_SECRET=replace-with-secret-value-not-secret-id
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Synapse
SYNAPSE_DEV_ENDPOINT=https://yourworkspace.dev.azuresynapse.net
